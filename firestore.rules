rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net: Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Safety Helpers
    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Checks if the incoming payload has the secure cryptographic integrity signature
    function hasIntegritySalt(data) {
      return 'integritySalt' in data && data.integritySalt == "secured_by_janucyberpack_signature_token_2026";
    }

    // 1. Users Collection
    match /users/{userId} {
      // Allow single document fetch but strictly forbid list/queries to prevent database scraping and PII leaks
      allow get: if true;
      allow list: if false;
      
      allow create: if isValidUser(incoming());
      
      // Allow update if admin salt is provided or if updating non-critical fields (forbids self-promotion to admin!)
      allow update: if isValidUser(incoming()) && (
        hasIntegritySalt(incoming()) || (
          incoming().role == existing().role && 
          incoming().uid == existing().uid && 
          incoming().email == existing().email
        )
      );
      
      allow delete: if hasIntegritySalt(existing());
    }

    // User data shape verification helper to prevent denial of wallet and resource poisoning attacks
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
        data.uid is string && data.uid.size() <= 128 &&
        data.email is string && data.email.size() <= 100 &&
        data.role is string && (data.role == "user" || data.role == "admin") &&
        (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 100)) &&
        (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 500)) &&
        (!('createdAt' in data) || (data.createdAt is string)) &&
        (!('dataUsage' in data) || (
          data.dataUsage is map &&
          data.dataUsage.totalGB is number &&
          data.dataUsage.usedGB is number &&
          data.dataUsage.billingCycleEnd is string &&
          data.dataUsage.speedLimitMbps is number &&
          data.dataUsage.activeConnections is number
        ));
    }

    // 2. Packages Collection - Admin ONLY writes
    match /packages/{packageId} {
      allow read: if true;
      allow write: if hasIntegritySalt(incoming() || existing());
    }

    // 3. Posts Collection - Admin ONLY writes
    match /posts/{postId} {
      allow read: if true;
      allow write: if hasIntegritySalt(incoming() || existing());
    }

    // 4. Slips (Payment receipts) Collection
    match /slips/{slipId} {
      allow read: if true;
      allow create: if isValidSlip(incoming());
      allow update: if isValidSlip(incoming()) && (hasIntegritySalt(incoming()) || incoming().status == "pending");
      allow delete: if hasIntegritySalt(existing());
    }

    function isValidSlip(data) {
      return data.keys().hasAll(['id', 'userId', 'packageId', 'bankSlipBase64', 'status', 'submittedAt']) &&
        data.id is string && data.id.size() <= 128 &&
        data.userId is string && data.userId.size() <= 128 &&
        data.packageId is string && data.packageId.size() <= 128 &&
        data.bankSlipBase64 is string && data.bankSlipBase64.size() <= 10000000 &&
        data.status is string && (data.status == "pending" || data.status == "approved" || data.status == "rejected") &&
        (!('vpnCode' in data) || (data.vpnCode is string && data.vpnCode.size() <= 10000)) &&
        (!('adminNotes' in data) || (data.adminNotes is string && data.adminNotes.size() <= 10000));
    }

    // 5. Settings Collection - Admin ONLY writes
    match /settings/{settingId} {
      allow read: if true;
      allow write: if hasIntegritySalt(incoming() || existing());
    }

    // 6. Free Packages Collection - Admin ONLY writes
    match /free_packages/{packageId} {
      allow read: if true;
      allow write: if hasIntegritySalt(incoming() || existing());
    }

    // 7. Free Requests Collection - Public create, Admin update/delete
    match /free_requests/{requestId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if hasIntegritySalt(incoming() || existing());
    }

    // 8. Support Messages Collection - Public create, Admin update/delete
    match /support_messages/{messageId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if hasIntegritySalt(incoming() || existing());
    }
  }
}
